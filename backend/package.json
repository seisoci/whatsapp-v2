{
  "name": "backend-auth-api",
  "version": "1.0.0",
  "description": "Secure authentication API with Bun, Hono, TypeORM, and PostgreSQL",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "migration:generate": "bun typeorm migration:generate",
    "migration:run": "bun typeorm migration:run",
    "migration:revert": "bun typeorm migration:revert",
    "typeorm": "typeorm-ts-node-commonjs",
    "meili:sync": "bun src/scripts/meili-sync.ts"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.74.1",
    "dotenv": "^16.6.1",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.57.0",
    "minio": "^7.1.4",
    "multer": "^1.4.5-lts.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "ua-parser-js": "^2.0.9",
    "ws": "^8.20.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/form-data": "^2.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
